{
  "name": "nexora",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "dev:web": "pnpm --filter @nexora/web dev",
    "dev:server": "pnpm --filter @nexora/server dev",
    "build:web": "pnpm --filter @nexora/web build",
    "build:server": "pnpm --filter @nexora/server build",
    "test": "pnpm --filter @nexora/web test"
  }
}
