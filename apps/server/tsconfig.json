{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@nexora/ai-engine": ["../../packages/ai-engine/src"],
      "@nexora/analytics": ["../../packages/analytics/src"],
      "@nexora/automation": ["../../packages/automation/src"],
      "@nexora/commerce": ["../../packages/commerce/src"],
      "@nexora/database": ["../../packages/database/src"],
      "@nexora/knowledge": ["../../packages/knowledge/src"],
      "@nexora/shared": ["../../packages/shared/src"],
      "@nexora/collaboration": ["../../packages/collaboration/src"],
      "@nexora/security": ["../../packages/security/src"],
      "@nexora/marketplace": ["../../packages/marketplace/src"],
      "@nexora/creator": ["../../packages/creator/src"],
      "@nexora/lms": ["../../packages/lms/src"],
      "@nexora/search": ["../../packages/search/src"]
    }
  },
  "include": ["src/**/*"]
}
