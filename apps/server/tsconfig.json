{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@nexora/analytics": ["../../packages/analytics/src"],
      "@nexora/commerce": ["../../packages/commerce/src"],
      "@nexora/database": ["../../packages/database/src"],
      "@nexora/knowledge": ["../../packages/knowledge/src"],
      "@nexora/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src/**/*"]
}
